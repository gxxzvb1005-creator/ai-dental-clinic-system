      "name": "Edit Fields1"
    },
    {
      "parameters": {
        "jsCode": "const schedule = $('Get a row1').first().json;\nconst workStart = schedule.start_time;\nconst workEnd = schedule.end_time;\n\nconst appointments = $('Get many rows').all().map(item => ({\n  start: item.json.start_time,\n  end: item.json.end_time\n}));\n\nfunction toMinutes(timeStr) {\n  const [h, m] = timeStr.split(':').map(Number);\n  return h * 60 + m;\n}\n\nfunction toTimeStr(minutes) {\n  const h = Math.floor(minutes / 60);\n  const m = minutes % 60;\n  return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`;\n}\n\nconst workStartMin = toMinutes(workStart);\nconst workEndMin = toMinutes(workEnd);\n\n// رتب الحجوزات من الأقدم للأحدث\nconst booked = appointments\n  .map(a => ({ start: toMinutes(a.start), end: toMinutes(a.end) }))\n  .sort((a, b) => a.start - b.start);\n\n// اوجد الفراغات\nconst available = [];\nlet cursor = workStartMin;\n\nfor (const booking of booked) {\n  if (cursor < booking.start) {\n    available.push({ start: toTimeStr(cursor), end: toTimeStr(booking.start) });\n  }\n  cursor = Math.max(cursor, booking.end);\n}\n\n// الفراغ بعد آخر حجز لحد نهاية الدوام\nif (cursor < workEndMin) {\n  available.push({ start: toTimeStr(cursor), end: toTimeStr(workEndMin) });\n}\n\nreturn available.map(slot => ({ json: slot }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
