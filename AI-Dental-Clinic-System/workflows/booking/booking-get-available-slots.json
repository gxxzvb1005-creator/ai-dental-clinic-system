              "name": "Text",
              "value": "=The day that corresponds to {{ $('Code in JavaScript').item.json.day_name }} By date {{ $('Code in JavaScript').item.json.date }} All available time slots from {{ $('Get a row1').item.json.start_time }} To {{ $('Get a row1').item.json.end_time }}",
