    {
      "parameters": {
        "jsCode": "const appointmentStart24 = $('Code in JavaScript1').first().json.appointment_end_24h;\nconst appointmentStartOrig = $('Code in JavaScript1').first().json.appointment_start;\nconst appointmentEnd24 = $('Code in JavaScript1').first().json.appointment_end_24h;\n\n// جيب مواعيد العمل من Get a row2\nconst workStart = $('Get a row2').first().json.start_time; // \"09:00:00\"\nconst workEnd = $('Get a row2').first().json.end_time;     // \"17:00:00\"\n\n// حوّل كل الأوقات لدقائق عشان المقارنة تبقى سهلة\nfunction timeToMinutes(timeStr) {\n  // يشتغل مع \"HH:MM:SS\" و \"HH:MM\"\n  const parts = timeStr.split(':').map(Number);\n  return parts[0] * 60 + parts[1];\n}\n\nfunction parse12hToMinutes(timeStr) {\n  timeStr = timeStr.trim();\n  const isPM = /pm/i.test(timeStr);\n  const isAM = /am/i.test(timeStr);\n  const clean = timeStr.replace(/[apm\\s]/gi, '');\n  let [h, m] = clean.split(':').map(Number);\n  if (isPM && h !== 12) h += 12;\n  if (isAM && h === 12) h = 0;\n  return h * 60 + m;\n}\n\nconst startMinutes = parse12hToMinutes(appointmentStartOrig);\nconst endMinutes   = timeToMinutes(appointmentEnd24);\nconst workStartMin = timeToMinutes(workStart);\nconst workEndMin   = timeToMinutes(workEnd);\n\nconst isAvailable = startMinutes >= workStartMin && endMinutes <= workEndMin;\n\nreturn [{\n  json: {\n    appointment_start: appointmentStartOrig,\n    appointment_end: $('Code in JavaScript1').first().json.appointment_end_12h,\n    work_hours: `${workStart.slice(0,5)} - ${workEnd.slice(0,5)}`,\n    status: isAvailable ? 'available' : 'not available'\n  }\n}];"
      },
