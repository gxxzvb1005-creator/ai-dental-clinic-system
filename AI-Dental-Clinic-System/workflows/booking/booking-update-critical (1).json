    {
      "parameters": {
        "jsCode": "const triggerData = JSON.parse($('When Executed by Another Workflow').first().json.query);\nconst appointmentTime = triggerData.appointment_context.requested_time;\nconst durationMinutes = $('Get a row3').first().json.duration_minutes;\n\nfunction parseTimeTo24h(timeStr) {\n  timeStr = timeStr.trim();\n  const isPM = /pm/i.test(timeStr);\n  const isAM = /am/i.test(timeStr);\n  const clean = timeStr.replace(/[apm\\s]/gi, '');\n  let [h, m] = clean.split(':').map(Number);\n  if (isPM && h !== 12) h += 12;\n  if (isAM && h === 12) h = 0;\n  return { h, m };\n}\n\nconst { h, m } = parseTimeTo24h(appointmentTime);\n\nconst totalMinutes = h * 60 + m + durationMinutes;\nconst endH = Math.floor(totalMinutes / 60) % 24;\nconst endM = totalMinutes % 60;\n\nfunction to12h(hours, mins) {\n  const period = hours >= 12 ? 'PM' : 'AM';\n  const h12 = hours % 12 || 12;\n  return `${h12}:${String(mins).padStart(2, '0')} ${period}`;\n}\n\nreturn [{\n  json: {\n    appointment_start: appointmentTime,\n    appointment_end_24h: `${String(endH).padStart(2, '0')}:${String(endM).padStart(2, '0')}`,\n    appointment_end_12h: to12h(endH, endM),\n    duration_minutes: durationMinutes\n  }\n}];;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2352,
        -192
